              fontSize: 18,
              fontWeight: FontWeight.w900,
              color: Colors.black,
            ),
          ),
          const SizedBox(height: 10),
          Wrap(
            spacing: 8,
            runSpacing: 8,
            children: [
              _metricChip('Total', '$total'),
              _metricChip('Queued', '$queued'),
              _metricChip('Processed', '$processed'),
            ],
          ),
          const SizedBox(height: 12),
          Wrap(
            spacing: 8,
            runSpacing: 8,
            children: [
              FilledButton.icon(
                onPressed: _queueBusy ? null : _enqueueTestPush,
                icon: const Icon(Icons.queue),
                label: const Text('Enqueue test'),
              ),
              FilledButton.icon(
                onPressed: _queueBusy ? null : _loadQueueState,
                icon: const Icon(Icons.refresh),
                label: const Text('Refresh queue'),
              ),
              OutlinedButton.icon(
                onPressed: _queueBusy ? null : _processQueue,
                icon: const Icon(Icons.play_arrow),
