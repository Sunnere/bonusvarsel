                  crossAxisAlignment: CrossAxisAlignment.start,
                  children: [
                    Text(
                      '${queueItem['id'] ?? '-'}',
                      style: const TextStyle(
                        fontWeight: FontWeight.w900,
                      ),
                    ),
                    const SizedBox(height: 8),
                    Wrap(
                      spacing: 8,
                      runSpacing: 8,
                      children: [
                        _metricChip('Status', '${queueItem['status'] ?? '-'}'),
                        _metricChip('Created', '${queueItem['createdAt'] ?? '-'}'),
