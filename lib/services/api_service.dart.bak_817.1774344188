  }) async {
    final body = <String, dynamic>{};
    if (rate != null) body['rate'] = rate;
    if (rateText != null) body['rateText'] = rateText;
    if (campaign != null) body['campaign'] = campaign;
    if (expires != null) body['expires'] = expires;
    if (level != null) body['level'] = level;
    if (storeId != null) body['storeId'] = storeId;

    final res = await http
        .put(
          _uri('/v1/offers/$id'),
          headers: {'Content-Type': 'application/json'},
          body: jsonEncode(body),
        )
        .timeout(const Duration(seconds: 4));

    if (res.statusCode < 200 || res.statusCode >= 300) {
      throw Exception('PUT /v1/offers/$id failed: ${res.statusCode} ${res.body}');
    }

    final decoded = jsonDecode(res.body);
