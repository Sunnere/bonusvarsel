    final targetPoints = _suggestedTargetPoints();
    final pointsGap = (targetPoints - projectedSasPoints).clamp(0, 999999999);

    final packingNeeds = _buildPackingNeeds();
    final storeSuggestions = _buildStoreSuggestions(packingNeeds);

    final cardName = CardCatalog.nameFor(_selectedCardId);
    final cardLabel = (_selectedCardId == null)
        ? 'Gå til "Kort" og velg et kort'
        : 'Valgt kort: $cardName • $_cardRatePer100 poeng per 100 kr';

    return Scaffold(
      backgroundColor: _travelPageBg,
      appBar: AppBar(
        title: const Text('Reise'),
        actions: [
          IconButton(
