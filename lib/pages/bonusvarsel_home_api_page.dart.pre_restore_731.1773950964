            ),
          ),
          if (_feedControlsExpanded) ...[
            const SizedBox(height: 12),
            Text(
              'Sist oppdatert: $_lastFeedRefreshAt',
              style: TextStyle(
                color: AppTheme.textMuted,
                fontWeight: FontWeight.w700,
              ),
            ),
            const SizedBox(height: 12),
            SwitchListTile(
              contentPadding: EdgeInsets.zero,
              title: const Text('Kun kampanjer'),
              value: _uiOnlyCampaigns,
              onChanged: (value) {
                setState(() => _uiOnlyCampaigns = value);
              },
