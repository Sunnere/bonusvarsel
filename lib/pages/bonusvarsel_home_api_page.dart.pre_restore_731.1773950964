                DropdownMenuItem(
                  value: 'score_desc',
                  child: Text('Beste deal-score først'),
                ),
                DropdownMenuItem(
                  value: 'rate_desc',
                  child: Text('Høyeste rate først'),
                ),
                DropdownMenuItem(
                  value: 'store_asc',
                  child: Text('Butikknavn A–Å'),
