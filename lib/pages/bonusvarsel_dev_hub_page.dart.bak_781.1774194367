              OutlinedButton.icon(
                onPressed: _queueBusy ? null : _clearQueue,
                icon: const Icon(Icons.clear_all),
                label: const Text('Clear queue'),
              ),
            ],
          ),
          const SizedBox(height: 14),
          const Text(
            'Queue items',
            style: TextStyle(
              fontWeight: FontWeight.w900,
              color: Colors.black,
            ),
          ),
          const SizedBox(height: 10),
          if (items.isEmpty)
            const Text(
              'Ingen queue-items ennå.',
              style: TextStyle(fontWeight: FontWeight.w700),
            )
          else
            ...items.take(10).map<Widget>((item) {
              final queueItem = item as Map<String, dynamic>;
              final payload = queueItem['payload'] as Map<String, dynamic>?;
              final dispatch = payload?['dispatch'] as Map<String, dynamic>?;
              final evaluation = payload?['evaluation'] as Map<String, dynamic>?;

              return Container(
                width: double.infinity,
                margin: const EdgeInsets.only(bottom: 10),
