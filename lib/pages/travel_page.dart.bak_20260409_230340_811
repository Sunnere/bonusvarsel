  String _formatInt(int value) {
    final s = value.toString();
    final chunks = <String>[];
    for (int i = s.length; i > 0; i -= 3) {
      final start = (i - 3 < 0) ? 0 : i - 3;
      chunks.insert(0, s.substring(start, i));
    }
    return chunks.join(' ');
  }

