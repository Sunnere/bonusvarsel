class BonusvarselHomeApiPage extends StatefulWidget {
  const BonusvarselHomeApiPage({super.key});

  @override
  State<BonusvarselHomeApiPage> createState() => _BonusvarselHomeApiPageState();
}

class _BonusvarselHomeApiPageState extends State<BonusvarselHomeApiPage> {
  late Future<Map<String, dynamic>> _meFuture;
  late Future<Map<String, dynamic>> _prefsFuture;
  late Future<List<FeedItem>> _feedFuture;
  bool _uiOnlyCampaigns = false;
  String _feedSort = 'default';
  String _lastFeedRefreshAt = '-';
  bool _feedLegendExpanded = true;
  bool _feedControlsExpanded = true;
  bool _prefsExpanded = true;
  bool _upgradeExpanded = true;
  final TextEditingController _purchaseAmountCtrl = TextEditingController(text: '5000');
  String? _selectedStoreId;
  String? _comparisonStoreId;

  @override
  void initState() {
    super.initState();
    _load();
  }

  void _load() {
    _meFuture = ApiService.getMe();
    _prefsFuture = ApiService.getPrefs();
    _feedFuture = ApiService.getFeed();
    _lastFeedRefreshAt = DateTime.now().toIso8601String();
  }

  Future<void> _refresh() async {
    setState(_load);
    await Future.wait<dynamic>([
      _meFuture,
      _prefsFuture,
      _feedFuture,
    ]);
  }

  Widget _sectionTitle(String text) {
    return Padding(
      padding: const EdgeInsets.only(bottom: 10, top: 18),
      child: Text(
        text,
        style: const TextStyle(
          fontSize: 24,
          fontWeight: FontWeight.w800,
        ),
      ),
    );
  }

  Widget _loadingBox() {
    return AnimatedContainer(
      duration: const Duration(milliseconds: 180),
      curve: Curves.easeOut,
      width: double.infinity,
      padding: const EdgeInsets.all(18),
      decoration: BoxDecoration(
        borderRadius: BorderRadius.circular(22),
        color: Colors.black.withValues(alpha: 0.18),
      ),
      child: const Center(child: CircularProgressIndicator()),
    );
  }

  Widget _errorBox(Object error) {
    return AnimatedContainer(
      duration: const Duration(milliseconds: 180),
      curve: Curves.easeOut,
      width: double.infinity,
      padding: const EdgeInsets.all(18),
      decoration: BoxDecoration(
        color: const Color(0xFF34161A),
        borderRadius: BorderRadius.circular(20),
        border: Border.all(color: AppTheme.danger),
      ),
      child: Row(
        crossAxisAlignment: CrossAxisAlignment.start,
        children: [
          const Padding(
            padding: EdgeInsets.only(top: 1),
            child: Icon(Icons.error_outline, color: AppTheme.danger),
          ),
          const SizedBox(width: 10),
          Expanded(
            child: Text(
