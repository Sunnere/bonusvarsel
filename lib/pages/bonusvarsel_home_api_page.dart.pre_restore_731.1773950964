  Future<void> _registerDemoDevice() async {
    final result = await ApiService.registerDevice(
      token: 'flutter-demo-token',
      platform: 'web',
    );

    if (!mounted) return;
    ScaffoldMessenger.of(context).showSnackBar(
      SnackBar(content: Text('Enhet registrert: ${result['count']} totalt')),
    );
  }

  @override
  void dispose() {
    _purchaseAmountCtrl.dispose();
    super.dispose();
  }

  @override
  Widget build(BuildContext context) {
    return Scaffold(
      appBar: AppBar(
        title: const Text('Bonusvarsel'),
        bottom: PreferredSize(
          preferredSize: Size.fromHeight(1),
          child: Container(
            height: 1,
            color: AppTheme.border,
          ),
        ),
        actions: [
          IconButton(
            tooltip: 'Dev Hub',
            onPressed: () {
              Navigator.of(context).push(
                MaterialPageRoute(
                  builder: (_) => const BonusvarselDevHubPage(),
                ),
              );
            },
            icon: const Icon(Icons.bug_report_outlined),
          ),
          IconButton(
            onPressed: _refresh,
            icon: const Icon(Icons.refresh),
            tooltip: 'Oppdater',
          ),
        ],
      ),
      body: RefreshIndicator(
        onRefresh: _refresh,
        child: FutureBuilder<List<dynamic>>(
          future: Future.wait<dynamic>([
            _meFuture,
            _prefsFuture,
            _feedFuture,
          ]),
          builder: (context, snapshot) {
            if (snapshot.connectionState != ConnectionState.done) {
              return ListView(
                padding: const EdgeInsets.all(18),
                children: [_loadingBox()],
              );
            }

            if (snapshot.hasError) {
              return ListView(
                padding: const EdgeInsets.all(18),
                children: [_errorBox(snapshot.error!)],
              );
            }

            final me = snapshot.data![0] as Map<String, dynamic>;
            final prefs = snapshot.data![1] as Map<String, dynamic>;
            final feed = snapshot.data![2] as List<FeedItem>;
            final tier = (me['tier'] ?? 'free').toString();

            return ListView(
              padding: const EdgeInsets.all(18),
              children: [
                _hero(me, prefs),
                const SizedBox(height: 18),
                _dashboardStats(
                  me: me,
                  prefs: prefs,
                  feed: feed,
                ),
                const SizedBox(height: 18),
                _pointsSimulatorCard(feed),
                const SizedBox(height: 18),
                _actionsCard(),
                _livePrefsCard(),
                _sectionTitle('Preferences'),
                _prefsCard(prefs),
                _sectionTitle('Hvorfor oppgradere?'),
                _whyUpgradeCard(tier),
                _sectionTitle('Feed'),
                _feedLegend(),
                const SizedBox(height: 18),
                _feedControls(),
                const SizedBox(height: 18),
                _feedList(feed, tier),
                const SizedBox(height: 24),
                ],
              ),
            );
          },
        ),
      ),
    );
  }
}
