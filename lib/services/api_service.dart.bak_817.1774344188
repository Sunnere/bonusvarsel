  static Future<Map<String, dynamic>> getActivatedNotifications({
    bool reset = false,
  }) async {
    final suffix = reset ? '?reset=1' : '';
    final decoded = await _getMap('/v1/notifications/activated$suffix');

    final raw = decoded['notifications'];
    if (raw is List) {
      decoded['notifications'] = raw
          .map((e) => ActivatedNotification.fromJson(
                Map<String, dynamic>.from(e as Map),
              ))
          .toList();
    } else {
      decoded['notifications'] = <ActivatedNotification>[];
    }

    return decoded;
  }

