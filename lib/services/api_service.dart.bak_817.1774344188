class ApiService {
  static const String _nativeDefaultBaseUrl = 'http://127.0.0.1:8080';
  static const String _envBaseUrl = String.fromEnvironment('API_BASE', defaultValue: '');

  static String _webBaseUrl() {
    final base = Uri.base;
    final host = base.host;

    if (host.contains('-8090.')) {
      final apiHost = host.replaceFirst('-8090.', '-8080.');
      return '${base.scheme}://$apiHost';
    }

    if (base.port == 8090) {
      return '${base.scheme}://${base.host}:8080';
    }

    if (host == 'localhost' || host == '127.0.0.1') {
      return '${base.scheme}://$host:8080';
    }

    return '${base.scheme}://${base.host}${base.hasPort ? ':8080' : ':8080'}';
  }

  static String get baseUrl {
    if (_envBaseUrl.isNotEmpty) {
      return _envBaseUrl;
    }
    if (kIsWeb) {
      return _webBaseUrl();
    }
    return _nativeDefaultBaseUrl;
  }

  static Uri _uri(String path) => Uri.parse('$baseUrl$path');

  static Future<Map<String, dynamic>> _getMap(String path) async {
    final res = await http.get(_uri(path)).timeout(const Duration(seconds: 4));

    if (res.statusCode < 200 || res.statusCode >= 300) {
      throw Exception('GET $path failed: ${res.statusCode} ${res.body}');
    }

    final decoded = jsonDecode(res.body);
    if (decoded is! Map<String, dynamic>) {
      throw Exception('GET $path expected JSON object');
    }

    return decoded;
  }

  static Future<List<dynamic>> _getList(String path) async {
    final res = await http.get(_uri(path)).timeout(const Duration(seconds: 4));

    if (res.statusCode < 200 || res.statusCode >= 300) {
      throw Exception('GET $path failed: ${res.statusCode} ${res.body}');
    }

    final decoded = jsonDecode(res.body);
    if (decoded is! List) {
      throw Exception('GET $path expected JSON list');
    }

    return decoded;
  }


