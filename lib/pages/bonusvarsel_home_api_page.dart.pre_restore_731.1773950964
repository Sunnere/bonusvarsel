  int _dealScore(FeedItem item) {
    var score = item.rate.round();

    if (item.campaign) {
      score += 5;
    }

    switch (item.level) {
      case 'boost':
        score += 1;
        break;
      case 'premium':
        score += 2;
        break;
      case 'elite':
        score += 3;
        break;
      default:
        break;
    }

    return score;
  }

  String _dealScoreLabel(FeedItem item) {
    return 'Score ${_dealScore(item)}';
  }




  String _bestNextAction(FeedItem item, {int? topRank}) {
    final momentum = _dealMomentum(item, topRank: topRank);

    if (item.lockedForFree) {
      return 'Oppgrader før kjøp';
    }

    if (item.campaign && momentum > 24) {
      return 'Kjøp nå – sterk kampanje';
    }

    if (topRank == 1) {
      return 'Beste deal akkurat nå';
    }

    if (momentum > 18) {
      return 'Sterk deal';
    }

    return 'Se an';
  }


  int _dealMomentum(FeedItem item, {int? topRank}) {
    var momentum = _dealScore(item);

    if (item.campaign) {
      momentum += 4;
    }

    if (topRank != null) {
      if (topRank == 1) {
        momentum += 6;
      } else if (topRank == 2) {
        momentum += 4;
      } else if (topRank == 3) {
        momentum += 2;
      }
    }

    switch (item.level) {
      case 'elite':
        momentum += 3;
        break;
      case 'premium':
        momentum += 2;
        break;
      case 'boost':
        momentum += 1;
        break;
      default:
        break;
    }

    return momentum;
  }


  ({String label, Color color, Color? textColor}) _timingDecision(
    FeedItem item, {
    int? topRank,
  }) {
    final momentum = _dealMomentum(item, topRank: topRank);

    if (item.lockedForFree) {
      return (
        label: 'VENT / OPPGRADER',
        color: Colors.blueGrey,
        textColor: Colors.white,
      );
    }

    if (item.campaign && (momentum >= 24 || topRank == 1)) {
      return (
        label: 'KJØP NÅ',
        color: Colors.green,
        textColor: Colors.white,
      );
    }

    if (momentum >= 20) {
      return (
        label: 'GODT KJØPSVINDU',
        color: Colors.lightGreen,
        textColor: Colors.black,
      );
    }

    return (
      label: 'VENT',
      color: Colors.orange,
      textColor: Colors.black,
    );
  }


  ({String label, Color color, Color? textColor}) _momentumStyle(
    FeedItem item, {
    int? topRank,
  }) {
    final momentum = _dealMomentum(item, topRank: topRank);

    if (momentum >= 28) {
      return (
        label: 'TRENDING NOW',
        color: const Color(0xFFD4AF37),
        textColor: const Color(0xFF7A5A00),
      );
    }

    if (momentum >= 22) {
      return (
        label: 'HOT',
        color: Colors.red,
        textColor: null,
      );
    }

    if (momentum >= 16) {
      return (
        label: 'STRONG',
        color: Colors.deepPurple,
        textColor: null,
      );
    }

    return (
      label: 'WATCH',
      color: Colors.blueGrey,
      textColor: Colors.white,
    );
  }


  Map<String, int> _topDealRanks(List<FeedItem> items) {
    final visibleItems = _applyFeedView(items);

    final ranked = List<FeedItem>.from(visibleItems)
      ..sort((a, b) {
        final scoreCompare = _dealScore(b).compareTo(_dealScore(a));
        if (scoreCompare != 0) return scoreCompare;
        return b.rate.compareTo(a.rate);
      });

    final result = <String, int>{};
    for (var i = 0; i < ranked.length && i < 3; i++) {
      result[ranked[i].id] = i + 1;
    }
    return result;
  }


  Widget _feedList(List<FeedItem> items, String tier) {
    final visibleItems = _applyFeedView(items);

    if (visibleItems.isEmpty) {
      return Column(
        children: [
          _feedSummary(
            visibleCount: 0,
            totalCount: items.length,
          ),
          const SizedBox(height: 14),
          Container(
            width: double.infinity,
            padding: const EdgeInsets.all(18),
            decoration: BoxDecoration(
              borderRadius: BorderRadius.circular(22),
              color: AppTheme.surface,
              border: Border.all(color: AppTheme.border),
            ),
            child: const Row(
              children: [
                Icon(Icons.inbox_outlined, color: AppTheme.textMuted),
                SizedBox(width: 10),
                Expanded(
                  child: Text(
                    'Ingen tilbud akkurat nå.',
                    style: TextStyle(
                      color: AppTheme.textSoft,
                      fontWeight: FontWeight.w700,
                    ),
                  ),
                ),
              ],
            ),
          ),
        ],
      );
    }

    bool canSee(FeedItem item) {
      if (!item.lockedForFree) return true;
      if (tier == 'elite') return true;
      if (tier == 'premium' && item.level != 'elite') return true;
      return false;
    }

    final topRanks = _topDealRanks(items);

    return Column(
      children: [
        _feedSummary(
          visibleCount: visibleItems.length,
          totalCount: items.length,
        ),
        const SizedBox(height: 14),
        ...visibleItems.map<Widget>((item) {
          final unlocked = canSee(item);
          final topRank = topRanks[item.id];
          final momentum = _momentumStyle(item, topRank: topRank);
          final timingDecision = _timingDecision(item, topRank: topRank);
          final levelColor = item.level == 'elite'
              ? const Color(0xFFD4AF37)
              : item.level == 'premium'
                  ? const Color(0xFF2F80ED)
                  : item.level == 'boost'
                      ? Colors.orange
                      : Colors.grey;

          return Container(
            margin: const EdgeInsets.only(bottom: 12),
            padding: const EdgeInsets.all(18),
            decoration: BoxDecoration(
              borderRadius: BorderRadius.circular(22),
              color: AppTheme.surface,
              border: Border.all(color: AppTheme.border),
              boxShadow: [
                BoxShadow(
                  color: Colors.black.withValues(alpha: 0.18),
                  blurRadius: 10,
                  offset: const Offset(0, 3),
                ),
              ],
            ),
            child: Column(
              crossAxisAlignment: CrossAxisAlignment.start,
              children: [
                Row(
                  children: [
                    Expanded(
                      child: Text(
                        item.store,
                        style: const TextStyle(
                          fontSize: 19,
                          fontWeight: FontWeight.w900,
                        ),
                      ),
                    ),
                    if (topRank != null)
                      Padding(
                        padding: const EdgeInsets.only(right: 8),
                        child: _badge(
                          label: '#$topRank TOP DEAL',
                          color: topRank == 1
                              ? const Color(0xFFD4AF37)
                              : topRank == 2
                                  ? Colors.blueGrey
                                  : Colors.brown,
                          textColor: topRank == 1
                              ? const Color(0xFF7A5A00)
                              : Colors.white,
                        ),
                      ),
                    _badge(
                      label: momentum.label,
                      color: momentum.color,
                      textColor: momentum.textColor,
                    ),
                    if (item.campaign)
                      Padding(
                        padding: const EdgeInsets.only(left: 8),
                        child: _badge(
                          label: 'CAMPAIGN',
                          color: Colors.red,
                        ),
                      ),
                  ],
                ),
                const SizedBox(height: 12),
                Text(
                  unlocked
                      ? item.rateText
                      : '🔒 ${item.level.toUpperCase()} • Oppgrader for full rate',
                  style: const TextStyle(
                    fontSize: 26,
                    fontWeight: FontWeight.w900,
                    color: AppTheme.text,
                    height: 1.1,
                  ),
                ),
                const SizedBox(height: 12),
                const SizedBox(height: 12),
                _badge(
                  label: timingDecision.label,
                  color: timingDecision.color,
                  textColor: timingDecision.textColor,
                ),
                const SizedBox(height: 12),
                Wrap(
                  spacing: 8,
                  runSpacing: 8,
                  children: [
                    _badge(
                      label: item.level.toUpperCase(),
                      color: levelColor,
                    ),
                    _badge(
                      label: _dealScoreLabel(item),
                      color: Colors.deepPurple,
                    ),
                    _badge(
                      label: 'Momentum ${_dealMomentum(item, topRank: topRank)}',
                      color: Colors.orange,
                    ),
                    _badge(
                      label: item.source.toUpperCase(),
                      color: Colors.indigo,
                    ),
                    _badge(
                      label: item.category,
                      color: Colors.teal,
                    ),
                  ],
                ),
                const SizedBox(height: 14),
                const SizedBox(height: 12),
                Text(
                  'Action: ${_bestNextAction(item, topRank: topRank)}',
                  style: const TextStyle(
                    fontWeight: FontWeight.w800,
                    fontSize: 13.5,
                    color: AppTheme.textSoft,
                    height: 1.25,
                  ),
                ),
                const SizedBox(height: 6),
                Text(
                  'Expires: ${item.expires}',
                  style: TextStyle(
                    color: AppTheme.textMuted,
                    fontWeight: FontWeight.w700,
                  ),
                ),
              ],
            ),
          );
        }),
      ],
    );
  }



  Future<void> _refreshFeedOnly() async {
    setState(() {
      _feedFuture = ApiService.getFeed();
      _lastFeedRefreshAt = DateTime.now().toIso8601String();
    });
    await _feedFuture;
  }

  String _feedSortLabel() {
    switch (_feedSort) {
      case 'score_desc':
        return 'Beste deal-score først';
      case 'rate_desc':
        return 'Høyeste rate først';
      case 'store_asc':
        return 'Butikknavn A–Å';
      default:
        return 'Standard';
    }
  }

  List<FeedItem> _applyFeedView(List<FeedItem> items) {
    var result = List<FeedItem>.from(items);

    if (_uiOnlyCampaigns) {
      result = result.where((item) => item.campaign).toList();
    }

    switch (_feedSort) {
      case 'score_desc':
        result.sort((a, b) {
          final scoreCompare = _dealScore(b).compareTo(_dealScore(a));
          if (scoreCompare != 0) return scoreCompare;
          return b.rate.compareTo(a.rate);
        });
        break;
      case 'rate_desc':
        result.sort((a, b) => b.rate.compareTo(a.rate));
        break;
      case 'store_asc':
        result.sort((a, b) => a.store.toLowerCase().compareTo(b.store.toLowerCase()));
        break;
      default:
        break;
    }

    return result;
  }

  Widget _badge({
    required String label,
    required Color color,
    Color? textColor,
  }) {
    return Container(
      padding: const EdgeInsets.symmetric(horizontal: 12, vertical: 7),
      decoration: BoxDecoration(
        borderRadius: BorderRadius.circular(999),
        color: color.withValues(alpha: 0.10),
        border: Border.all(color: color.withValues(alpha: 0.30)),
      ),
      child: Text(
        label,
        style: TextStyle(
          color: textColor ?? color,
          fontWeight: FontWeight.w800,
          fontSize: 11.5,
          height: 1.0,
        ),
      ),
    );
  }

  Widget _feedSummary({
    required int visibleCount,
    required int totalCount,
  }) {
    return Container(
      width: double.infinity,
      padding: const EdgeInsets.all(16),
      decoration: BoxDecoration(
        borderRadius: BorderRadius.circular(22),
        color: AppTheme.surface,
        border: Border.all(color: AppTheme.border),
      ),
      child: Wrap(
        spacing: 8,
        runSpacing: 8,
        children: [
          _badge(
            label: 'Viser $visibleCount av $totalCount',
            color: Colors.indigo,
          ),
          _badge(
            label: _feedSortLabel(),
            color: Colors.teal,
          ),
          if (_uiOnlyCampaigns)
            _badge(
              label: 'Kun kampanjer',
              color: Colors.red,
            ),
        ],
      ),
    );
  }


