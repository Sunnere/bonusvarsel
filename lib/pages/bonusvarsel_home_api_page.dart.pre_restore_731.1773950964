  Widget _dashboardStats({
    required Map<String, dynamic> me,
    required Map<String, dynamic> prefs,
    required List<FeedItem> feed,
  }) {
    final tier = (me['tier'] ?? 'free').toString();
    final visibleCount = _applyFeedView(feed).length;
    final campaignCount = feed.where((item) => item.campaign).length;

    return Row(
      children: [
        Expanded(
          child: _statusStatCard(
            label: 'Tier',
            value: tier.toUpperCase(),
            icon: _tierIcon(tier),
          ),
        ),
        const SizedBox(width: 10),
        Expanded(
          child: _statusStatCard(
            label: 'Visible',
            value: '$visibleCount',
            icon: Icons.visibility_outlined,
          ),
        ),
        const SizedBox(width: 10),
        Expanded(
          child: _statusStatCard(
            label: 'Campaigns',
            value: '$campaignCount',
            icon: Icons.local_fire_department_outlined,
          ),
        ),
      ],
    );
  }



  double _estimatedPoints({
    required double purchaseAmount,
    required FeedItem item,
  }) {
    return (purchaseAmount * item.rate) / 100.0;
  }

  Widget _pointsSimulatorCard(List<FeedItem> feed) {
    final availableFeed = _applyFeedView(feed);
    final stores = availableFeed.isNotEmpty ? availableFeed : feed;

    if (stores.isEmpty) {
      return Container(
        width: double.infinity,
        padding: const EdgeInsets.all(18),
        decoration: BoxDecoration(
          borderRadius: BorderRadius.circular(22),
          color: AppTheme.surface,
          border: Border.all(color: AppTheme.border),
        ),
        child: const Text(
          'Ingen deals tilgjengelig for simulator akkurat nå.',
          style: TextStyle(fontWeight: FontWeight.w700),
        ),
      );
    }

    final selectedId = stores.any((item) => item.id == _selectedStoreId)
        ? _selectedStoreId
        : stores.first.id;

    final fallbackComparisonId = stores.length > 1 ? stores[1].id : stores.first.id;
    final comparisonId = stores.any((item) => item.id == _comparisonStoreId)
        ? _comparisonStoreId
        : fallbackComparisonId;

    final selectedItem = stores.firstWhere((item) => item.id == selectedId);
    final comparisonItem = stores.firstWhere((item) => item.id == comparisonId);

    final purchaseAmount =
        double.tryParse(_purchaseAmountCtrl.text.replaceAll(',', '.')) ?? 0.0;

    final estimatedA = _estimatedPoints(
      purchaseAmount: purchaseAmount,
      item: selectedItem,
    );
    final estimatedB = _estimatedPoints(
      purchaseAmount: purchaseAmount,
      item: comparisonItem,
    );

    final bestItem = estimatedA >= estimatedB ? selectedItem : comparisonItem;
    final bestEstimate = estimatedA >= estimatedB ? estimatedA : estimatedB;
    final diff = (estimatedA - estimatedB).abs();

    return AnimatedContainer(
      duration: const Duration(milliseconds: 180),
      curve: Curves.easeOut,
      width: double.infinity,
      padding: const EdgeInsets.all(18),
      decoration: BoxDecoration(
        borderRadius: BorderRadius.circular(22),
        color: AppTheme.surface,
        border: Border.all(color: AppTheme.border),
        boxShadow: [
          BoxShadow(
            color: Colors.black.withValues(alpha: 0.22),
            blurRadius: 16,
            offset: const Offset(0, 6),
          ),
        ],
      ),
      child: Column(
        crossAxisAlignment: CrossAxisAlignment.start,
        children: [
          const Text(
            'Poeng-simulator',
            style: TextStyle(
              fontSize: 19,
              fontWeight: FontWeight.w900,
            ),
          ),
          const SizedBox(height: 8),
          Text(
            'Sammenlign to deals og se hvilket valg som gir best estimert opptjening.',
            style: const TextStyle(
              color: AppTheme.textMuted,
              fontWeight: FontWeight.w700,
              height: 1.35,
            ),
          ),
          const SizedBox(height: 14),
          DropdownButtonFormField<String>(
            initialValue: selectedId,
            decoration: const InputDecoration(
              labelText: 'Deal A',
            ),
            items: stores
                .map(
                  (item) => DropdownMenuItem(
                    value: item.id,
                    child: Text('${item.store} • ${item.rateText}'),
                  ),
                )
                .toList(),
            onChanged: (value) {
              if (value == null) return;
              setState(() => _selectedStoreId = value);
            },
          ),
          const SizedBox(height: 14),
          DropdownButtonFormField<String>(
            initialValue: comparisonId,
            decoration: const InputDecoration(
              labelText: 'Deal B',
            ),
            items: stores
                .map(
                  (item) => DropdownMenuItem(
                    value: item.id,
                    child: Text('${item.store} • ${item.rateText}'),
                  ),
                )
                .toList(),
            onChanged: (value) {
              if (value == null) return;
              setState(() => _comparisonStoreId = value);
            },
          ),
          const SizedBox(height: 14),
          TextField(
            controller: _purchaseAmountCtrl,
            keyboardType: const TextInputType.numberWithOptions(decimal: true),
            decoration: const InputDecoration(
              labelText: 'Kjøpesum',
              prefixText: 'kr ',
            ),
            onChanged: (_) => setState(() {}),
          ),
          const SizedBox(height: 14),
          Wrap(
            spacing: 8,
            runSpacing: 8,
            children: [
              _badge(
                label: 'A: ${selectedItem.store}',
                color: Colors.indigo,
              ),
              _badge(
                label: estimatedA.toStringAsFixed(0),
                color: Colors.indigo,
              ),
              _badge(
                label: 'B: ${comparisonItem.store}',
                color: Colors.teal,
              ),
              _badge(
                label: estimatedB.toStringAsFixed(0),
                color: Colors.teal,
              ),
            ],
          ),
          const SizedBox(height: 14),
          Text(
            'Beste valg: ${bestItem.store} • ca. ${bestEstimate.toStringAsFixed(0)} poeng/opptjening.',
            style: const TextStyle(
              fontWeight: FontWeight.w900,
            ),
          ),
          const SizedBox(height: 6),
          Text(
            'Forskjell mellom A og B: ca. ${diff.toStringAsFixed(0)} poeng.',
            style: const TextStyle(
              fontWeight: FontWeight.w800,
            ),
          ),
        ],
      ),
    );
  }


