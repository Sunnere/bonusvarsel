  @override
  State<BonusvarselDevHubPage> createState() => _BonusvarselDevHubPageState();
}


class _StaticInfoChip extends StatelessWidget {
  final String label;
  final String value;

  const _StaticInfoChip({
    required this.label,
    required this.value,
  });

  @override
  Widget build(BuildContext context) {
    return Container(
      padding: const EdgeInsets.symmetric(horizontal: 10, vertical: 8),
      decoration: BoxDecoration(
        borderRadius: BorderRadius.circular(999),
        color: Colors.black.withValues(alpha: 0.06),
        border: Border.all(color: const Color(0xFFE5E7EB)),
      ),
      child: Text(
        '$label: $value',
        style: const TextStyle(
          fontWeight: FontWeight.w800,
          fontSize: 12,
        ),
      ),
    );
  }
}

class _BonusvarselDevHubPageState extends State<BonusvarselDevHubPage> {
  Map<String, dynamic>? _systemHealth;
  // AI_ANCHOR: DEV_HUB_STATE_START
  bool _sendingTestPush = false;
  bool _queueBusy = false;
  bool _simulatingAlert = false;
  bool _pushTestExpanded = true;
  Map<String, dynamic>? _lastSendTestResult;
  Map<String, dynamic>? _queueState;
  Map<String, dynamic>? _alertSimulationResult;
  final List<Map<String, dynamic>> _alertSimulationHistory = [];
  final Set<int> _expandedHistoryRows = {};
  int? _pinnedSimulationIndex;
  int _simRate = 18;
  String _simLevel = 'premium';
  bool _simCampaign = true;

  String _lastSendTestStatus = 'idle';
  bool _loadingHealth = false;

  final _pushTestKey = GlobalKey();
  final _dispatchKey = GlobalKey();
  final _devicesKey = GlobalKey();


  // AI_ANCHOR: DEV_HUB_LIFECYCLE_START
  @override
  void initState() {
    super.initState();
    _loadSystemHealth();
    _loadQueueState();
  }

  Future<void> _loadSystemHealth() async {
    setState(() => _loadingHealth = true);

    try {
      final health = await ApiService.getHealth();
      final feed = await ApiService.getFeed();
      final notifications = await ApiService.getActivatedNotifications();

      if (!mounted) return;

      setState(() {
        _systemHealth = {
          'apiOk': health['ok'] == true,
          'feedCount': feed.length,
          'notificationCount': notifications['count'] ?? 0,
          'checkedAt': DateTime.now().toIso8601String(),
        };
      });
    } catch (e) {
      if (!mounted) return;
      setState(() {
        _systemHealth = {
          'apiOk': false,
          'feedCount': 0,
          'notificationCount': 0,
          'checkedAt': DateTime.now().toIso8601String(),
          'error': e.toString(),
        };
      });
    } finally {
      if (mounted) {
        setState(() => _loadingHealth = false);
      }
    }
  }

  Future<void> _sendTestPush() async {
    setState(() {
      _sendingTestPush = true;
      _lastSendTestStatus = 'running';
    });

    try {
      final res = await ApiService.sendTestPush();
      if (!mounted) return;

      setState(() {
        _lastSendTestResult = res;
        _lastSendTestStatus = 'success';
      });

      ScaffoldMessenger.of(context).showSnackBar(
        SnackBar(
          content: Text(
            'Test-push ok • sent: ${res['sentCount'] ?? 0} • dispatches: ${res['dispatchCount'] ?? 0}',
          ),
        ),
      );
    } catch (e) {
      if (!mounted) return;

      setState(() {
        _lastSendTestResult = {
          'error': e.toString(),
          'failedAt': DateTime.now().toIso8601String(),
        };
        _lastSendTestStatus = 'error';
      });

      ScaffoldMessenger.of(context).showSnackBar(
        SnackBar(content: Text('Test-push feilet: $e')),
      );
    } finally {
      if (mounted) {
        setState(() => _sendingTestPush = false);
      }
    }
  }


  String _simulationSummaryText(Map<String, dynamic> entry) {
    final offer = entry['offer'] as Map<String, dynamic>?;
    final evaluation = entry['evaluation'] as Map<String, dynamic>?;

    return [
      'Bonusvarsel simulation',
      'Rate: ${offer?['rateText'] ?? '-'}',
      'Level: ${offer?['level'] ?? '-'}',
      'Campaign: ${offer?['campaign'] ?? '-'}',
      'Score: ${evaluation?['score'] ?? '-'}',
      'Momentum: ${evaluation?['momentum'] ?? '-'}',
      'Timing: ${evaluation?['timing'] ?? '-'}',
      'Notify: ${evaluation?['shouldNotify'] ?? '-'}',
      'Reason: ${(evaluation?['reason'] ?? '-').toString()}',
      'Simulated at: ${entry['simulatedAt'] ?? '-'}',
    ].join('\n');
  }



  Widget _entry(
    BuildContext context, {
    required IconData icon,
    required String title,
    required String subtitle,
    required Widget page,
    Key? containerKey,
  }) {
    return Container(
      key: containerKey,
      margin: const EdgeInsets.only(bottom: 12),
      decoration: BoxDecoration(
        borderRadius: BorderRadius.circular(18),
        color: const Color(0xFF111827),
        border: Border.all(color: const Color(0xFFE5E7EB)),
      ),
      child: ListTile(
        leading: Icon(icon),
        title: Text(
          title,
          style: const TextStyle(fontWeight: FontWeight.w800),
        ),
        subtitle: Text(subtitle),
        trailing: const Icon(Icons.chevron_right),
        onTap: () {
          Navigator.of(context).push(
            MaterialPageRoute(builder: (_) => page),
          );
        },
      ),
    );
  }






  Future<void> _triggerAlertSimulation() async {
    setState(() => _simulatingAlert = true);

    try {
      final res = await ApiService.simulateAlert();
      if (!mounted) return;

      setState(() {
        _alertSimulationResult = res;
        _alertSimulationHistory.insert(0, Map<String, dynamic>.from(res));
        if (_alertSimulationHistory.length > 8) {
          _alertSimulationHistory.removeRange(8, _alertSimulationHistory.length);
        }
      });

      ScaffoldMessenger.of(context).showSnackBar(
        const SnackBar(content: Text('Alert simulation ok')),
      );
    } catch (e) {
      if (!mounted) return;

      ScaffoldMessenger.of(context).showSnackBar(
        SnackBar(content: Text('Alert simulation feilet: $e')),
      );
    } finally {
      if (mounted) {
        setState(() => _simulatingAlert = false);
      }
    }
  }











  // AI_ANCHOR: DEV_HUB_ALERT_HISTORY_START
  

