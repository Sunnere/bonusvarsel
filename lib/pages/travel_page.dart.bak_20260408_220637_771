    if (isWarm) {
      needs.addAll([
        _PackingNeed(
          label: 'Solkrem',
          quantity: _familySize,
          priority: 'Høy',
          category: 'Helse / apotek',
          storeHint: 'Apotek, helse, hudpleie',
        ),
        _PackingNeed(
          label: 'Badetøy',
          quantity: _familySize,
          priority: 'Høy',
          category: 'Klær',
          storeHint: 'Sport, klær, strand',
        ),
        _PackingNeed(
          label: 'Strandhåndklær',
          quantity: _familySize,
          priority: 'Middels',
          category: 'Strand / fritid',
          storeHint: 'Sport, hjem, fritid',
        ),
        _PackingNeed(
          label: 'Snorkelutstyr',
          quantity: _children > 0 ? _children : 2,
          priority: 'Lav',
          category: 'Sport / fritid',
          storeHint: 'Sport, fritid, strand',
        ),
      ]);
    }

    if (isCold) {
      needs.addAll([
        _PackingNeed(
          label: 'Ullundertøy',
          quantity: _familySize,
          priority: 'Høy',
          category: 'Klær',
          storeHint: 'Sport, klær',
        ),
        _PackingNeed(
          label: 'Hansker / luer',
          quantity: _familySize,
          priority: 'Høy',
          category: 'Klær',
          storeHint: 'Sport, klær',
        ),
        _PackingNeed(
          label: 'Håndvarmere / vintertilbehør',
          quantity: _familySize,
          priority: 'Middels',
          category: 'Vinterutstyr',
          storeHint: 'Sport, vinter, fritid',
        ),
      ]);
    }

    if (_days >= 10) {
      needs.add(
        _PackingNeed(
          label: 'Toalettsaker / refill',
          quantity: 1,
          priority: 'Middels',
          category: 'Helse / apotek',
          storeHint: 'Apotek, dagligvarer',
        ),
      );
    }

    if (_selectedTripType == 'Byferie') {
      needs.add(
        _PackingNeed(
          label: 'Komfortable gåsko',
          quantity: _familySize,
          priority: 'Middels',
          category: 'Sko / klær',
          storeHint: 'Klær, sport, sko',
        ),
      );
    }

    if (_selectedTripType == 'Aktiv ferie') {
      needs.add(
        _PackingNeed(
          label: 'Sportsklær / treningsutstyr',
          quantity: _familySize,
          priority: 'Middels',
          category: 'Sport',
          storeHint: 'Sport, fritid',
        ),
      );
    }

    return needs;
  }

  List<_StoreSuggestion> _buildStoreSuggestions(List<_PackingNeed> needs) {
    final categories = <String>{};
    final hints = <String>{};

    for (final need in needs) {
      categories.add(need.category);
      hints.add(need.storeHint);
    }

    final results = <_StoreSuggestion>[];

    if (categories.contains('Bagasje')) {
      results.add(
        const _StoreSuggestion(
          title: 'Bagasje og kofferter',
          why: 'Høy relevans for familie, flere kolli og organisering.',
        ),
      );
    }

    if (categories.contains('Helse / apotek')) {
      results.add(
        const _StoreSuggestion(
          title: 'Apotek og helsebutikk',
          why: 'Bra for solkrem, reiseapotek og hygiene før tur.',
        ),
      );
    }

    if (categories.contains('Sport / fritid') ||
        categories.contains('Sport') ||
        categories.contains('Vinterutstyr')) {
      results.add(
        const _StoreSuggestion(
          title: 'Sportsbutikk / friluft',
          why: 'God match for strandutstyr, vinterutstyr og aktiv ferie.',
        ),
      );
    }

    if (categories.contains('Klær') || categories.contains('Sko / klær')) {
      results.add(
        const _StoreSuggestion(
          title: 'Klesbutikk / skobutikk',
          why: 'Relevant for badetøy, gåsko, ull og familieklær.',
        ),
      );
    }

    if (categories.contains('Elektronikk')) {
      results.add(
        const _StoreSuggestion(
          title: 'Elektronikkbutikk',
          why: 'Bra for powerbank, ladere og reiseteknologi.',
        ),
      );
    }

    if (_children > 0) {
      results.add(
        const _StoreSuggestion(
          title: 'Barn og familiebutikk',
          why: 'Smart for småbarnsutstyr, aktiviteter og familietilbehør.',
        ),
      );
    }

    if (results.isEmpty) {
      results.add(
        _StoreSuggestion(
          title: 'Relevante butikker i appen',
          why: 'Se etter kategorier som matcher: ${hints.join(', ')}.',
        ),
      );
    }

    return results.take(5).toList();
  }

  int _suggestedTargetPoints() {
    final base = _children > 0 ? 160000 : 100000;
    final extraDays = (_days > 7) ? ((_days - 7) * 2500) : 0;
    return base + extraDays;
  }

