  ({String label, Color color}) _compareSummary({
    required num scoreDiff,
    required num momentumDiff,
    required bool latestDecision,
    required bool previousDecision,
  }) {
    if (latestDecision && !previousDecision) {
      return (label: 'Improved signal', color: Colors.green);
    }

    if (!latestDecision && previousDecision) {
      return (label: 'Weaker than previous', color: Colors.red);
    }

    final combined = scoreDiff + momentumDiff;

    if (combined >= 3) {
      return (label: 'Improved signal', color: Colors.green);
    }

    if (combined <= -3) {
      return (label: 'Weaker than previous', color: Colors.red);
    }

    return (label: 'No material change', color: Colors.blueGrey);
  }




  ({String label, Color color}) _pinnedCompareSummary({
    required num scoreDiff,
    required num momentumDiff,
    required bool latestDecision,
    required bool pinnedDecision,
  }) {
    if (latestDecision && !pinnedDecision) {
      return (label: 'Better than pinned', color: Colors.green);
    }

    if (!latestDecision && pinnedDecision) {
      return (label: 'Worse than pinned', color: Colors.red);
    }

    final combined = scoreDiff + momentumDiff;

    if (combined >= 3) {
      return (label: 'Better than pinned', color: Colors.green);
    }

    if (combined <= -3) {
      return (label: 'Worse than pinned', color: Colors.red);
    }

    return (label: 'Matches pinned baseline', color: Colors.blueGrey);
  }


  Widget _compareAgainstPinnedCard() {
    if (_alertSimulationResult == null || _pinnedSimulationIndex == null) {
      return const SizedBox.shrink();
    }

    if (_pinnedSimulationIndex! < 0 ||
        _pinnedSimulationIndex! >= _alertSimulationHistory.length) {
      return const SizedBox.shrink();
    }

    final latest = _alertSimulationResult!;
    final pinned = _alertSimulationHistory[_pinnedSimulationIndex!];

    final latestEval = latest['evaluation'] as Map<String, dynamic>?;
    final pinnedEval = pinned['evaluation'] as Map<String, dynamic>?;

    if (latestEval == null || pinnedEval == null) {
      return const SizedBox.shrink();
    }

    final latestScore = (latestEval['score'] as num?) ?? 0;
    final pinnedScore = (pinnedEval['score'] as num?) ?? 0;
    final latestMomentum = (latestEval['momentum'] as num?) ?? 0;
    final pinnedMomentum = (pinnedEval['momentum'] as num?) ?? 0;
    final latestDecision = latestEval['shouldNotify'] == true;
    final pinnedDecision = pinnedEval['shouldNotify'] == true;

    final scoreDiff = latestScore - pinnedScore;
    final momentumDiff = latestMomentum - pinnedMomentum;
    final summary = _pinnedCompareSummary(
      scoreDiff: scoreDiff,
      momentumDiff: momentumDiff,
      latestDecision: latestDecision,
      pinnedDecision: pinnedDecision,
    );

    String diffText(num value) {
      if (value > 0) return '+${value.toString()}';
      return value.toString();
    }

    Color diffColor(num value) {
      if (value > 0) return Colors.green;
      if (value < 0) return Colors.red;
      return Colors.blueGrey;
    }

    return Container(
      width: double.infinity,
      margin: const EdgeInsets.only(top: 12),
      padding: const EdgeInsets.all(14),
      decoration: BoxDecoration(
        borderRadius: BorderRadius.circular(16),
        color: Colors.black.withValues(alpha: 0.03),
        border: Border.all(color: Colors.black12),
      ),
      child: Column(
        crossAxisAlignment: CrossAxisAlignment.start,
        children: [
          const Text(
            'Compare against pinned',
            style: TextStyle(
              fontWeight: FontWeight.w900,
              color: Colors.black,
            ),
          ),
          const SizedBox(height: 10),
          Container(
            padding: const EdgeInsets.symmetric(horizontal: 12, vertical: 10),
            decoration: BoxDecoration(
              borderRadius: BorderRadius.circular(999),
              color: summary.color.withValues(alpha: 0.10),
              border: Border.all(
                color: summary.color.withValues(alpha: 0.35),
              ),
            ),
            child: Text(
              summary.label,
              style: TextStyle(
                color: summary.color,
                fontWeight: FontWeight.w900,
              ),
            ),
          ),
          const SizedBox(height: 10),
          Wrap(
            spacing: 8,
            runSpacing: 8,
            children: [
              _metricChip('Score now', '$latestScore'),
              _metricChip('Score pinned', '$pinnedScore'),
              Container(
                padding: const EdgeInsets.symmetric(horizontal: 10, vertical: 8),
                decoration: BoxDecoration(
                  borderRadius: BorderRadius.circular(999),
                  color: diffColor(scoreDiff).withValues(alpha: 0.10),
                  border: Border.all(
                    color: diffColor(scoreDiff).withValues(alpha: 0.35),
                  ),
                ),
                child: Text(
                  'Δ Score ${diffText(scoreDiff)}',
                  style: TextStyle(
                    color: diffColor(scoreDiff),
                    fontWeight: FontWeight.w900,
                    fontSize: 12,
                  ),
                ),
              ),
              _metricChip('Momentum now', '$latestMomentum'),
              _metricChip('Momentum pinned', '$pinnedMomentum'),
              Container(
                padding: const EdgeInsets.symmetric(horizontal: 10, vertical: 8),
                decoration: BoxDecoration(
                  borderRadius: BorderRadius.circular(999),
                  color: diffColor(momentumDiff).withValues(alpha: 0.10),
                  border: Border.all(
                    color: diffColor(momentumDiff).withValues(alpha: 0.35),
                  ),
                ),
                child: Text(
                  'Δ Momentum ${diffText(momentumDiff)}',
                  style: TextStyle(
                    color: diffColor(momentumDiff),
                    fontWeight: FontWeight.w900,
                    fontSize: 12,
                  ),
                ),
              ),
              _metricChip('Timing now', '${latestEval['timing'] ?? '-'}'),
              _metricChip('Timing pinned', '${pinnedEval['timing'] ?? '-'}'),
              _metricChip(
                'Decision now',
                '${latestEval['shouldNotify'] ?? '-'}',
              ),
              _metricChip(
                'Decision pinned',
                '${pinnedEval['shouldNotify'] ?? '-'}',
              ),
            ],
          ),
        ],
      ),
    );
  }


  Widget _simulationCompareCard() {
    if (_alertSimulationHistory.length < 2) {
      return const SizedBox.shrink();
    }

    final latest = _alertSimulationHistory[0];
    final previous = _alertSimulationHistory[1];

    final latestEval = latest['evaluation'] as Map<String, dynamic>?;
    final previousEval = previous['evaluation'] as Map<String, dynamic>?;

    if (latestEval == null || previousEval == null) {
      return const SizedBox.shrink();
    }

    final latestScore = (latestEval['score'] as num?) ?? 0;
    final previousScore = (previousEval['score'] as num?) ?? 0;
    final latestMomentum = (latestEval['momentum'] as num?) ?? 0;
    final previousMomentum = (previousEval['momentum'] as num?) ?? 0;
    final latestDecision = latestEval['shouldNotify'] == true;
    final previousDecision = previousEval['shouldNotify'] == true;

    final scoreDiff = latestScore - previousScore;
    final momentumDiff = latestMomentum - previousMomentum;
    final summary = _compareSummary(
      scoreDiff: scoreDiff,
      momentumDiff: momentumDiff,
      latestDecision: latestDecision,
      previousDecision: previousDecision,
    );

    String diffText(num value) {
      if (value > 0) return '+${value.toString()}';
      return value.toString();
    }

    Color diffColor(num value) {
      if (value > 0) return Colors.green;
      if (value < 0) return Colors.red;
      return Colors.blueGrey;
    }

    return Container(
      width: double.infinity,
      margin: const EdgeInsets.only(top: 12),
      padding: const EdgeInsets.all(14),
      decoration: BoxDecoration(
        borderRadius: BorderRadius.circular(16),
        color: Colors.black.withValues(alpha: 0.03),
        border: Border.all(color: Colors.black12),
      ),
      child: Column(
        crossAxisAlignment: CrossAxisAlignment.start,
        children: [
          const Text(
            'Compare vs previous',
            style: TextStyle(
              fontWeight: FontWeight.w900,
              color: Colors.black,
            ),
          ),
          const SizedBox(height: 10),
          Container(
            padding: const EdgeInsets.symmetric(horizontal: 12, vertical: 10),
            decoration: BoxDecoration(
              borderRadius: BorderRadius.circular(999),
              color: summary.color.withValues(alpha: 0.10),
              border: Border.all(
                color: summary.color.withValues(alpha: 0.35),
              ),
            ),
            child: Text(
              summary.label,
              style: TextStyle(
                color: summary.color,
                fontWeight: FontWeight.w900,
              ),
            ),
          ),
          const SizedBox(height: 10),
          Wrap(
            spacing: 8,
            runSpacing: 8,
            children: [
              _metricChip('Score now', '$latestScore'),
              _metricChip('Score prev', '$previousScore'),
              Container(
                padding: const EdgeInsets.symmetric(horizontal: 10, vertical: 8),
                decoration: BoxDecoration(
                  borderRadius: BorderRadius.circular(999),
                  color: diffColor(scoreDiff).withValues(alpha: 0.10),
                  border: Border.all(
                    color: diffColor(scoreDiff).withValues(alpha: 0.35),
                  ),
                ),
                child: Text(
                  'Δ Score ${diffText(scoreDiff)}',
                  style: TextStyle(
                    color: diffColor(scoreDiff),
                    fontWeight: FontWeight.w900,
                    fontSize: 12,
                  ),
                ),
              ),
              _metricChip('Momentum now', '$latestMomentum'),
              _metricChip('Momentum prev', '$previousMomentum'),
              Container(
                padding: const EdgeInsets.symmetric(horizontal: 10, vertical: 8),
                decoration: BoxDecoration(
                  borderRadius: BorderRadius.circular(999),
                  color: diffColor(momentumDiff).withValues(alpha: 0.10),
                  border: Border.all(
                    color: diffColor(momentumDiff).withValues(alpha: 0.35),
                  ),
                ),
                child: Text(
                  'Δ Momentum ${diffText(momentumDiff)}',
                  style: TextStyle(
                    color: diffColor(momentumDiff),
                    fontWeight: FontWeight.w900,
                    fontSize: 12,
                  ),
                ),
              ),
              _metricChip('Timing now', '${latestEval['timing'] ?? '-'}'),
              _metricChip('Timing prev', '${previousEval['timing'] ?? '-'}'),
              _metricChip(
                'Decision now',
                '${latestEval['shouldNotify'] ?? '-'}',
              ),
              _metricChip(
                'Decision prev',
                '${previousEval['shouldNotify'] ?? '-'}',
              ),
            ],
          ),
        ],
      ),
    );
  }


  // AI_ANCHOR: DEV_HUB_ALERT_SIM_START
  Widget _alertSimulationCard() {
    final result = _alertSimulationResult;
    final offer = result?['offer'] as Map<String, dynamic>?;
    final evaluation = result?['evaluation'] as Map<String, dynamic>?;

    return Container(
      width: double.infinity,
      padding: const EdgeInsets.all(16),
      decoration: BoxDecoration(
        borderRadius: BorderRadius.circular(18),
        color: const Color(0xFF111827),
        border: Border.all(color: const Color(0xFFE5E7EB)),
      ),
      child: Column(
        crossAxisAlignment: CrossAxisAlignment.start,
        children: [
          const Text(
            'Alert simulation',
            style: TextStyle(
              fontSize: 18,
              fontWeight: FontWeight.w900,
              color: Colors.black,
            ),
          ),
          const SizedBox(height: 10),
          
          const SizedBox(height: 12),

          Row(
            children: [
              Expanded(
                child: TextField(
                  decoration: const InputDecoration(
                    labelText: 'Rate',
                  ),
                  controller: TextEditingController(text: _simRate.toString()),
                  keyboardType: TextInputType.number,
                  onChanged: (v) {
                    final n = int.tryParse(v);
                    if (n != null) setState(() => _simRate = n);
                  },
                ),
              ),
              const SizedBox(width: 12),
              Expanded(
                child: DropdownButton<String>(
                  value: _simLevel,
                  isExpanded: true,
                  items: const [
                    DropdownMenuItem(value: 'standard', child: Text('standard')),
                    DropdownMenuItem(value: 'boost', child: Text('boost')),
                    DropdownMenuItem(value: 'premium', child: Text('premium')),
                    DropdownMenuItem(value: 'elite', child: Text('elite')),
                  ],
                  onChanged: (v) {
                    if (v != null) setState(() => _simLevel = v);
                  },
                ),
              ),
              const SizedBox(width: 12),
              Switch(
                value: _simCampaign,
                onChanged: (v) {
                  setState(() => _simCampaign = v);
                },
              ),
            ],
          ),

FilledButton.icon(
            onPressed: _simulatingAlert ? null : _triggerAlertSimulation,
            icon: const Icon(Icons.bolt_outlined),
            label: Text(
              _simulatingAlert
                  ? 'Simulerer…'
                  : 'Trigger Alert Simulation',
            ),
          ),
          const SizedBox(height: 12),
          if (result == null)
            const Text(
              'Ingen simulering kjørt ennå.',
              style: TextStyle(fontWeight: FontWeight.w700),
            )
          else ...[
            _simulationCompareCard(),
            if (_alertSimulationHistory.length >= 2) const SizedBox(height: 12),
            _compareAgainstPinnedCard(),
            if (_pinnedSimulationIndex != null) const SizedBox(height: 12),
            if (offer != null)
              Wrap(
                spacing: 8,
                runSpacing: 8,
                children: [
                  _metricChip('Rate', '${offer['rateText'] ?? '-'}'),
                ],
              ),
            if (evaluation != null) ...[
              const SizedBox(height: 12),
              Builder(
                builder: (_) {
                  final summary = _alertSummary(evaluation);
                  return Container(
                    padding: const EdgeInsets.symmetric(
                      horizontal: 12,
                      vertical: 10,
                    ),
                    decoration: BoxDecoration(
                      borderRadius: BorderRadius.circular(999),
                      color: summary.color.withValues(alpha: 0.10),
                      border: Border.all(
                        color: summary.color.withValues(alpha: 0.35),
                      ),
                    ),
                    child: Text(
                      summary.label,
                      style: TextStyle(
                        color: summary.color,
                        fontWeight: FontWeight.w900,
                      ),
                    ),
                  );
                },
              ),
              const SizedBox(height: 12),
              _scoreMeter(
                label: 'Score',
                value: (evaluation['score'] as num?) ?? 0,
                maxValue: 35,
              ),
              const SizedBox(height: 10),
              _scoreMeter(
                label: 'Momentum',
                value: (() {
                  final raw = evaluation['momentum']?.toString().toLowerCase() ?? '';
                  if (raw == 'high') return 3;
                  if (raw == 'medium') return 2;
                  if (raw == 'low') return 1;
                  return 0;
                })(),
                maxValue: 40,
              ),
              const SizedBox(height: 12),
              Wrap(
                spacing: 8,
                runSpacing: 8,
                children: [
                  _metricChip('Score', '${evaluation['score'] ?? '-'}'),
                  _metricChip('Momentum', '${evaluation['momentum'] ?? '-'}'),
                  _metricChip('Timing', '${evaluation['timing'] ?? '-'}'),
                  _metricChip('Notify', '${evaluation['shouldNotify'] ?? '-'}'),
                ],
              ),
              const SizedBox(height: 10),
              Text(
                'Reason: ${(evaluation['reason'] ?? '-').toString()}',
                style: TextStyle(
                  color: Colors.black.withValues(alpha: 0.90),
                  fontWeight: FontWeight.w700,
                ),
              ),
              if (evaluation['cooldownRemainingSec'] != null) ...[
                const SizedBox(height: 6),
                Text(
                  'Cooldown remaining: ${evaluation['cooldownRemainingSec']} sec',
                  style: TextStyle(
                    color: Colors.black.withValues(alpha: 0.82),
                    fontWeight: FontWeight.w700,
                  ),
                ),
              ],
              _alertRuleDebugCard(evaluation),
              if (evaluation['timeline'] is List) ...[
                const SizedBox(height: 12),
                const Text(
                  'Decision timeline',
                  style: TextStyle(
                    fontWeight: FontWeight.w900,
                  ),
                ),
                const SizedBox(height: 8),
                ...((evaluation['timeline'] as List).map<Widget>((step) {
                  final item = step as Map<String, dynamic>;
                  final key = '${item['key'] ?? '-'}';
                  final value = item['value'];
                  final tone = _timelineColor(key, value);

                  return Container(
                    width: double.infinity,
                    margin: const EdgeInsets.only(bottom: 8),
                    padding: const EdgeInsets.symmetric(
                      horizontal: 10,
                      vertical: 10,
                    ),
                    decoration: BoxDecoration(
                      borderRadius: BorderRadius.circular(12),
                      color: tone.withValues(alpha: 0.08),
                      border: Border.all(
                        color: tone.withValues(alpha: 0.35),
                      ),
                    ),
                    child: Row(
                      children: [
                        Expanded(
                          child: Text(
                            key,
                            style: TextStyle(
                              fontWeight: FontWeight.w800,
                              color: tone,
                            ),
                          ),
                        ),
                        const SizedBox(width: 12),
                        Text(
                          '$value',
                          style: TextStyle(
                            color: tone,
                            fontWeight: FontWeight.w800,
                          ),
                        ),
                      ],
                    ),
                  );
                }).toList()),
              ],
            ],
            const SizedBox(height: 8),
            Text(
              'Simulated at: ${result['simulatedAt'] ?? '-'}',
              style: TextStyle(
                color: Colors.black.withValues(alpha: 0.82),
                fontWeight: FontWeight.w700,
              ),
            ),
          ],
        ],
      ),
    );
  }

  Future<void> _loadQueueState() async {
    try {
      final res = await ApiService.getPushQueue();
      if (!mounted) return;
      setState(() => _queueState = res);
    } catch (_) {}
  }

  Future<void> _enqueueTestPush() async {
    setState(() => _queueBusy = true);
    try {
      final res = await ApiService.enqueueTestPush();
      if (!mounted) return;
      setState(() => _queueState = {
            'queue': res['queue'],
            'items': res['items'],
          });
      ScaffoldMessenger.of(context).showSnackBar(
        SnackBar(
          content: Text(
            'Queue enqueue ok • queued: ${res['queuedCount'] ?? 0}',
          ),
        ),
      );
    } catch (e) {
      if (!mounted) return;
      ScaffoldMessenger.of(context).showSnackBar(
        SnackBar(content: Text('Queue enqueue feilet: $e')),
      );
    } finally {
      if (mounted) {
        setState(() => _queueBusy = false);
      }
    }
  }

  Future<void> _processQueue() async {
    setState(() => _queueBusy = true);
    try {
      final res = await ApiService.processPushQueue();
      if (!mounted) return;
      setState(() => _queueState = {
            'queue': res['result'],
            'items': res['items'],
          });
      ScaffoldMessenger.of(context).showSnackBar(
        const SnackBar(content: Text('Queue prosessert')),
      );
    } catch (e) {
      if (!mounted) return;
      ScaffoldMessenger.of(context).showSnackBar(
        SnackBar(content: Text('Process queue feilet: $e')),
      );
    } finally {
      if (mounted) {
        setState(() => _queueBusy = false);
      }
    }
  }

  Future<void> _clearQueue() async {
    setState(() => _queueBusy = true);
    try {
      final res = await ApiService.clearPushQueue();
      if (!mounted) return;
      setState(() => _queueState = {
            'queue': res['queue'],
            'items': const [],
          });
      ScaffoldMessenger.of(context).showSnackBar(
        const SnackBar(content: Text('Queue tømt')),
      );
    } catch (e) {
      if (!mounted) return;
      ScaffoldMessenger.of(context).showSnackBar(
        SnackBar(content: Text('Clear queue feilet: $e')),
      );
    } finally {
      if (mounted) {
        setState(() => _queueBusy = false);
      }
    }
  }

