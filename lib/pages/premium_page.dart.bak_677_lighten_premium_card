            : accent.withValues(alpha: 0.85))
        : (emphasis
            ? (isElite
                ? const Color(0xFFD4AF37).withValues(alpha: 0.58)
                : accent.withValues(alpha: 0.45))
            : cs.onSurface.withValues(alpha: 0.36));

    final bg = isElite
        ? (selected
            ? const Color(0xFF140F2A)
            : const Color(0xFF101826))
        : cs.surface.withValues(alpha: emphasis ? 0.92 : 0.80);

    return SizedBox(
      width: 285,
      child: InkWell(
        onTap: onTap,
        borderRadius: BorderRadius.circular(16),
        child: Container(
          padding: const EdgeInsets.all(14),
          decoration: BoxDecoration(
            color: isElite ? null : bg,
            gradient: isElite
                ? LinearGradient(
                    begin: Alignment.topLeft,
                    end: Alignment.bottomRight,
                    colors: selected
                        ? const [
                            Color(0xFF2A1754),
                            Color(0xFF16112F),
                            Color(0xFF0D1522),
                          ]
                        : const [
                            Color(0xFF1A2232),
                            Color(0xFF151B28),
                          ],
                  )
                : null,
            borderRadius: BorderRadius.circular(16),
            border: Border.all(color: borderColor, width: isElite ? 1.8 : 1.0),
            boxShadow: [
              BoxShadow(
                color: isElite
                    ? const Color(0xFFD4AF37).withValues(alpha: selected ? 0.22 : 0.10)
                    : Colors.black.withValues(alpha: 0.36),
                blurRadius: isElite ? 30 : 16,
                offset: const Offset(0, 10),
              ),
            ],
          ),
          child: Column(
            crossAxisAlignment: CrossAxisAlignment.start,
            children: [
              Row(
                children: [
                  Text(
                    title,
                    style: Theme.of(context).textTheme.titleMedium?.copyWith(
                          fontWeight: FontWeight.w900,
                          color: isElite ? const Color(0xFFFFE08A) : null,
                          letterSpacing: isElite ? 0.35 : null,
                        ),
                  ),
                  const Spacer(),
                  Container(
                    padding:
                        const EdgeInsets.symmetric(horizontal: 10, vertical: 6),
                    decoration: BoxDecoration(
                      color: isElite
                          ? const Color(0xFFD4AF37).withValues(alpha: 0.24)
                          : (emphasis ? accent : cs.onSurface)
                              .withValues(alpha: 0.36),
                      borderRadius: BorderRadius.circular(999),
                      border: Border.all(
                        color: isElite
                            ? const Color(0xFFD4AF37).withValues(alpha: 0.78)
                            : (emphasis ? accent : cs.onSurface)
                                .withValues(alpha: 0.36),
                      ),
                    ),
                    child: Text(
                      badge,
                      style: TextStyle(
                        fontWeight: FontWeight.w900,
                        color: emphasis ? accent : cs.onSurface.withValues(alpha: 0.75),
                        fontSize: 12,
                      ),
                    ),
                  ),
                ],
              ),
              const SizedBox(height: 10),
        if (note != null)
          Padding(
            padding: const EdgeInsets.only(bottom: 8),
            child: Text(
              note!,
              softWrap: true,
              style: Theme.of(context).textTheme.bodySmall?.copyWith(
                    fontWeight: FontWeight.w800,
                    color: cs.onSurface.withValues(alpha: 0.78),
                  ),
            ),
          ),

                      ...bullets.map(
                (b) => Padding(
                  padding: const EdgeInsets.only(bottom: 6),
                  child: Row(
                    crossAxisAlignment: CrossAxisAlignment.start,
                    children: [
Icon(
                        Icons.check_circle,
                        size: 16,
                        color: emphasis ? accent : cs.primary,
                      ),
                      const SizedBox(width: 8),
                      Expanded(
                        child: Text(
                          b,
                          style: Theme.of(context).textTheme.bodySmall?.copyWith(
                                fontWeight: FontWeight.w700,
                                color: cs.onSurface.withValues(alpha: 0.80),
                              ),
                        ),
                      ),
                    ],
                  ),
                ),
              ),
              const SizedBox(height: 8),
              SizedBox(
                width: double.infinity,
                child: FilledButton(
                  style: FilledButton.styleFrom(
                    backgroundColor: emphasis ? accent : cs.primary,
                    foregroundColor: emphasis ? Colors.black : cs.onPrimary,
                    textStyle: const TextStyle(fontWeight: FontWeight.w900),
                  ),
                  onPressed: onCta,
                  child: Text(
                    ctaLabel,
                    style: (ctaLabelColor == null) ? null : TextStyle(color: ctaLabelColor),
                  ),
                ),
              ),
              const SizedBox(height: 6),
              if (selected)
                Text(
                  '',
                  style: Theme.of(context).textTheme.bodySmall?.copyWith(
                        fontWeight: FontWeight.w900,
                        color: accent,
                      ),
                ),
            ],
          ),
        ),
      ),
    );
  }
}

