          ),
          if (_feedLegendExpanded) ...[
            const SizedBox(height: 12),
            const Text(
              'Deal Score = rate + campaign bonus + nivåbonus.',
              style: TextStyle(
                fontWeight: FontWeight.w700,
                height: 1.4,
              ),
            ),
            const SizedBox(height: 8),
            const Text(
              'Momentum bygger videre på score og løfter kampanjer samt Top 3-deals.',
              style: TextStyle(
                fontWeight: FontWeight.w700,
                height: 1.4,
              ),
            ),
            const SizedBox(height: 8),
            const Text(
