  Color _tierColor(String tier) {
    switch (tier) {
      case 'elite':
        return const Color(0xFFD4AF37);
      case 'premium':
        return const Color(0xFF2F80ED);
      case 'free':
      default:
        return Colors.white;
    }
  }

  IconData _tierIcon(String tier) {
    switch (tier) {
      case 'elite':
        return Icons.emoji_events;
      case 'premium':
        return Icons.workspace_premium;
      case 'free':
      default:
        return Icons.lock_outline;
    }
  }

  String _tierLabel(String tier) {
    switch (tier) {
      case 'elite':
        return 'Elite aktiv';
      case 'premium':
        return 'Premium aktiv';
      case 'free':
      default:
        return 'Gratis-bruker';
    }
  }

  String _tierHint(String tier) {
    switch (tier) {
      case 'elite':
        return 'Du ser alle standard-, premium- og elite-tilbud.';
      case 'premium':
        return 'Du ser standard, boost og premium. Elite er fortsatt låst.';
      case 'free':
      default:
        return 'Du ser standard. Boost, Premium og Elite er delvis låst.';
    }
  }

